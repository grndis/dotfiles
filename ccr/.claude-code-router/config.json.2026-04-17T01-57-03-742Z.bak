{
  "LOG": false,
  "CLAUDE_PATH": "",
  "HOST": "127.0.0.1",
  "PORT": 3456,
  "APIKEY": "",
  "API_TIMEOUT_MS": "600000",
  "PROXY_URL": "",
  "OPENAI_API_KEY": "$OPENAI_API_KEY",
  "GEMINI_API_KEY": "$GEMINI_API_KEY",
  "OPENROUTER_KEY": "$OPENROUTER_KEY",
  "COPILOT_TOKEN": "$COPILOT_TOKEN",
  "GCLOUD_GEMINI": "$GCLOUD_GEMINI",
  "HOME": "$HOME",
  "transformers": [
    {
      "path": "/Users/grandis/.claude-code-router/plugins/gemini-cli.js",
      "options": {
        "project": "$GCLOUD_GEMINI"
      }
    },
    {
      "name": "",
      "path": "/Users/grandis/.claude-code-router/plugins/qwen-cli.js",
      "options": {}
    },
    {
      "name": "qwen-code",
      "path": "/Users/grandis/.claude-code-router/plugins/qwen-code.js",
      "options": {}
    },
    {
      "path": "$HOME/.claude-code-router/plugins/rovo-cli.js",
      "options": {}
    }
  ],
  "Providers": [
    {
      "name": "opencode-qwen",
      "api_base_url": "https://opencode.ai/zen/go/v1/chat/completions",
      "api_key": "REDACTED_API_KEY",
      "models": ["qwen3.6-plus"]
    }
  ],
  "Router": {
    "default": "opencode-qwen,qwen3.6-plus",
    "background": "opencode-qwen,qwen3.6-plus",
    "think": "opencode-qwen,qwen3.6-plus",
    "longContext": "qwen,qwen3-coder-plus",
    "longContextThreshold": 800000,
    "webSearch": "opencode-qwen,qwen3.6-plus",
    "image": "opencode-qwen,qwen3.6-plus"
  }
}
